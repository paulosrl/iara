# Copie este arquivo para .env e ajuste conforme seu ambiente:
#   cp .env.example .env

# =============================================================================
# LM Studio (provedor local)
# =============================================================================
# URL do servidor LM Studio
# Docker / WSL:  use host.docker.internal (padrão)
# Local sem Docker: use localhost ou 127.0.0.1
LM_STUDIO_URL=http://host.docker.internal:1234/v1

# =============================================================================
# Azure OpenAI (provedor em nuvem) — opcional
# =============================================================================
# Endpoint do recurso Azure OpenAI (sem barra no final)
# Exemplo: https://meu-recurso.openai.azure.com
AZURE_OPENAI_ENDPOINT=

# Chave de API do recurso Azure OpenAI
AZURE_OPENAI_API_KEY=

# Nome do deployment padrão (obrigatório se usar Azure)
# Exemplo: gpt-4o, gpt-35-turbo
AZURE_OPENAI_DEPLOYMENT=

# Deployments adicionais para seleção na UI (separados por vírgula — opcional)
# Exemplo: gpt-4o,gpt-35-turbo,gpt-5
AZURE_OPENAI_DEPLOYMENTS=

# =============================================================================
# Logging (opcional)
# =============================================================================
# Caminho do arquivo de log (padrão: /app/app_errors.log dentro do container)
# LOG_FILE=/app/app_errors.log
